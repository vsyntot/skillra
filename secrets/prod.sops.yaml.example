# Copy to secrets/prod.sops.yaml and encrypt with SOPS + age.
# Do not put real plaintext values in Git.
env:
  SKILLRA_API_TOKEN: changeme-skillra-api-token
  SKILLRA_ADMIN_TOKEN: changeme-skillra-admin-token
  TELEGRAM_BOT_TOKEN: changeme-telegram-bot-token
  TELEGRAM_WEBHOOK_SECRET_TOKEN: changeme-secret-token
  MEILISEARCH_API_KEY: changeme-meilisearch-master-key
  MINIO_ROOT_PASSWORD: changeme-minio-password
  MINIO_SECRET_KEY: changeme-api-s3-password
  S3_SECRET_ACCESS_KEY: changeme-pipeline-s3-password
  S3_BACKUP_SECRET_ACCESS_KEY: changeme-backup-s3-password
  POSTGRES_PASSWORD: changeme-postgres-password

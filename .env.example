# Skillra local environment
# Local development defaults. Copy to .env and replace tokens before running services.
# Generated from infra/env/schema.yml. Do not edit examples by hand.

# Runtime
SKILLRA_RUNTIME_ENV=local
SKILLRA_PUBLIC_BASE_URL=http://localhost:8000
SKILLRA_API_HOST=0.0.0.0
SKILLRA_API_PORT=8000
SKILLRA_WEB_PORT=5173
LOG_LEVEL=INFO
LOG_FORMAT=kv
SENTRY_DSN=

# API authentication
SKILLRA_API_TOKEN=changeme-service-token
SKILLRA_ADMIN_TOKEN=changeme-admin-token
SKILLRA_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Data paths
SKILLRA_DATA_VOLUME_BASE=data
SKILLRA_DATA_DIR=data/processed/latest
SKILLRA_FEATURES_PATH=data/processed/latest/hh_features.parquet
SKILLRA_MARKET_VIEW_PATH=data/processed/latest/market_view.parquet
SKILLRA_DATASET_META_PATH=data/processed/latest/dataset_meta.json
SKILLRA_MARKET_SNAPSHOTS_PATH=data/processed/market_snapshots
SKILLRA_DATA_WATCH_INTERVAL=30.0
SKILLRA_MIN_MARKET_N=80

# Database and cache
DATABASE_URL=postgresql+asyncpg://skillra:skillra@localhost:5432/skillra
POSTGRES_DB=skillra
POSTGRES_USER=skillra
POSTGRES_PASSWORD=changeme-postgres-password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
REDIS_URL=redis://localhost:6379/0
REDIS_PORT=6379

# Search
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_API_KEY=changeme-meili-master-key
MEILISEARCH_PORT=7700
SKILLRA_MEILI_TASK_TIMEOUT_MS=120000
SKILLRA_MEILI_TASK_INTERVAL_MS=500
SKILLRA_DIRECT_INDEX_BATCH_SIZE=500

# Object storage
MINIO_ENDPOINT_URL=http://localhost:9000
MINIO_ROOT_USER=skillra
MINIO_ROOT_PASSWORD=changeme-minio-root-password
MINIO_ACCESS_KEY=skillra-api
MINIO_SECRET_KEY=changeme-api-s3-password
MINIO_BUCKET_RESUMES=skillra-resumes
MINIO_BUCKET_REPORTS=skillra-reports
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_ENDPOINT_URL=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=skillra-pipeline
S3_SECRET_ACCESS_KEY=changeme-pipeline-s3-password
S3_BACKUP_ACCESS_KEY_ID=skillra-backup
S3_BACKUP_SECRET_ACCESS_KEY=changeme-backup-s3-password
S3_BUCKET_RAW_HH=skillra-raw-hh
S3_BUCKET_PROCESSED=skillra-processed
S3_BUCKET_BACKUPS=skillra-backups
SKILLRA_STORAGE_S3_TIMEOUT_SECONDS=10.0
SKILLRA_STORAGE_S3_MAX_ATTEMPTS=2
SKILLRA_STORAGE_S3_MAX_CONCURRENCY=8
SKILLRA_MAX_RESUME_BYTES=10485760

# Web
VITE_API_BASE_URL=http://localhost:8000
VITE_SKILLRA_API_TOKEN=changeme-service-token
VITE_TELEGRAM_BOT_USERNAME=skillra_local_bot
VITE_SKILLRA_RUNTIME_ENV=local
VITE_ENABLE_EVIDENCE_EXPLAINER=0
VITE_EVIDENCE_EXPLAINER_ALLOWED_TELEGRAM_USER_IDS=

# Telegram bot
TELEGRAM_BOT_TOKEN=changeme-telegram-bot-token
TELEGRAM_BOT_USERNAME=skillra_local_bot
TELEGRAM_PROD_BOT_USERNAME=skillra_bot
TELEGRAM_ADMIN_IDS=
BOT_MODE=polling
TELEGRAM_PARSE_MODE=HTML
TELEGRAM_RATE_LIMIT_PER_SECOND=1.0
TELEGRAM_DIGEST_POLL_INTERVAL_SECONDS=60.0
TELEGRAM_DIGEST_WEEKDAY=0
TELEGRAM_DIGEST_TIME_LOCAL=10:00
TELEGRAM_DIGEST_TIMEZONE=Europe/Moscow
SKILLRA_API_BASE_URL=http://localhost:8000
SKILLRA_API_CONNECT_TIMEOUT=5.0
SKILLRA_API_READ_TIMEOUT=15.0
SKILLRA_API_MAX_RETRIES=2
SKILLRA_API_RETRY_BACKOFF_SECONDS=0.5
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET_TOKEN=changeme-webhook-secret-token
TELEGRAM_WEBHOOK_HOST=0.0.0.0
TELEGRAM_WEBHOOK_PORT=8080
TELEGRAM_WEBHOOK_PATH=/webhook
TELEGRAM_DROP_PENDING_UPDATES=0
TELEGRAM_DELETE_WEBHOOK_ON_SHUTDOWN=0
TELEGRAM_SMOKE_CHAT_ID=

# Digest worker
DIGEST_POLL_INTERVAL=60
DIGEST_WORKER_HEARTBEAT_PATH=/tmp/digest_worker_heartbeat
DIGEST_WORKER_HEARTBEAT_MAX_AGE_SECONDS=300
DIGEST_WORKER_METRICS_PATH=
DIGEST_WORKER_HEARTBEAT_METRICS_PATH=

# Pipeline
SKILLRA_REFRESH_HH=0
SKILLRA_USE_RAW_HH_LATEST=0
SKILLRA_S3_SYNC=0
SKILLRA_REQUIRE_RAW_S3_COMMIT=0
SKILLRA_DATA_RUN_ID=
HH_STORAGE_DIR=data/raw/hh
HH_QUERY=
HH_LIMIT=
HH_SALARY_ONLY=0
HH_API_USER_AGENT=
HH_API_TOKEN=
SKILLRA_HH_API_TOKEN=
SKILLRA_JOB_SOURCE_MODE=hh_html
SKILLRA_JOB_FIXTURE_CSV=
SKILLRA_RAW_HH_MIN_ROWS=1
SKILLRA_QUALITY_MIN_ROWS=100
SKILLRA_QUALITY_MAX_DUPLICATE_SHARE=0.0
SKILLRA_QUALITY_MIN_SALARY_KNOWN_SHARE=0.01
DATA_SCHEDULER_UTC_HOUR=2
DATA_SCHEDULER_UTC_MINUTE=0
DATA_SCHEDULER_MAX_RETRIES=3
DATA_SCHEDULER_RETRY_DELAY_SECONDS=60

# Product controls
RATE_LIMIT_PERSONA=30/minute
RATE_LIMIT_MARKET=60/minute
RATE_LIMIT_DEFAULT=200/minute
RATE_LIMIT_USER_API_KEY=100/minute
RATE_LIMIT_IP=30/minute
SUBSCRIPTION_MAX_ATTEMPT=5
SUBSCRIPTION_BACKOFF_SECONDS=3600
SKILLRA_B2B_MIN_COHORT_N=10
SKILLRA_B2B_MIN_CELL_N=5
SKILLRA_BILLING_FAKE_WEBHOOK_ENABLED=0
SKILLRA_BILLING_FAKE_WEBHOOK_SECRET=changeme-fake-billing-secret
SKILLRA_BILLING_SANDBOX_WEBHOOK_ENABLED=0
SKILLRA_BILLING_SANDBOX_WEBHOOK_SECRET=changeme-sandbox-billing-secret
SKILLRA_BILLING_SANDBOX_PROVIDER_NAME=manual_invoice
SKILLRA_BILLING_REAL_PROVIDER_LAUNCH_ENABLED=0
SKILLRA_EVIDENCE_EXPLAINER_ENABLED=0
SKILLRA_EVIDENCE_EXPLAINER_ALLOWED_TELEGRAM_USER_IDS=
SKILLRA_EVIDENCE_EXPLAINER_PROD_ENABLE_APPROVED=0

# Monitoring
GF_SECURITY_ADMIN_USER=skillra
GF_SECURITY_ADMIN_PASSWORD=changeme-grafana-password
SKILLRA_PG_BACKUP_METRICS_FILE=
SKILLRA_PG_RESTORE_DRILL_METRICS_FILE=
SKILLRA_EXPECTED_RUNTIME_ENV=local

www.skillra.ru {
    import security_headers
    encode zstd gzip

    redir https://skillra.ru{uri}
}

# Sprint-006 TASK-12: Web SPA — app.skillra.ru with SPA fallback
app.skillra.ru {
    import security_headers
    encode zstd gzip

    # Усиленный CSP для защиты X-Skillra-Token в localStorage (ADR-005)
    header Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' https://skillra.ru; img-src 'self' data:"

    rate_limit {
        zone web {
            key {remote_ip}
            events 200
            window 1m
        }
    }

    # SPA fallback is handled by skillra-web nginx (infra/nginx.conf try_files).
    reverse_proxy prod-skillra-web:80
}
